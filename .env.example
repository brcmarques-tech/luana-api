# Banco de dados (local: postgres://user:pass@localhost:5432/luana_db)
DATABASE_URL=postgres://user:password@localhost:5432/luana_db

# Chave de admin para criar sessões e fazer upload de assets
ADMIN_SECRET=troca-isso-por-algo-secreto

# Dias de acesso após o primeiro uso (padrão: 7)
ACCESS_DAYS=7

# Porta local (Render define automaticamente via PORT)
PORT=3003
